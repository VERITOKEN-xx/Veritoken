# Stellar network selected by the frontend.
# Supported values: testnet, mainnet. Default in code: testnet.
VITE_STELLAR_NETWORK=testnet

# Deployed KYC registry contract ID for the selected network.
VITE_KYC_REGISTRY_ID=

# Deployed compliance engine contract ID for the selected network.
VITE_COMPLIANCE_ENGINE_ID=

# Deployed invoice token contract ID for the selected network.
VITE_INVOICE_TOKEN_ID=

# Deployed property token contract ID for the selected network.
VITE_PROPERTY_TOKEN_ID=

# Deployed carbon credit token contract ID for the selected network.
VITE_CARBON_TOKEN_ID=
